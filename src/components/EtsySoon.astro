---
export interface Props {
  variant?: "button" | "button-secondary" | "inline";
  /** Primary label (default: "Shop on Etsy" or "Etsy" for inline). */
  label?: string;
}

const { variant = "button", label } = Astro.props;

const ETSY_URL =
  "https://www.etsy.com/listing/4504383249/hog-splitter-pro-the-ultimate-curling";

const displayLabel =
  label ?? (variant === "inline" ? "Etsy" : "Shop on Etsy");

const buttonClass = variant === "button-secondary" ? "button-secondary" : "button";
---

{
  variant === "inline" ? (
    <a
      class="etsy-inline-link"
      href={ETSY_URL}
      target="_blank"
      rel="noopener noreferrer"
    >
      {displayLabel}
    </a>
  ) : (
    <a
      class:list={[buttonClass]}
      href={ETSY_URL}
      target="_blank"
      rel="noopener noreferrer"
    >
      {displayLabel}
    </a>
  )
}
