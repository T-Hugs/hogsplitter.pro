---
import DeviceScreen from "../components/DeviceScreen.astro";
import EtsySoon from "../components/EtsySoon.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import testimonialsData from "../../testimonials.json";

const testimonials = testimonialsData.testimonials.map((t) => ({
  quote: t.testimonial.trim(),
  author: `${t.first_name} ${t.last_name.charAt(0)}.`,
}));
---

<SiteLayout
  title="Hog Splitter Pro | The stopwatch built for curling"
  description="Hog Splitter Pro is a stopwatch built for curling: paired back-to-hog and hog-to-hog splits, glanceable history, no resets, an e-paper display, and USB-C charging."
  ogImage="/images/main.jpg"
>
  <aside class="fulfillment-notice" role="status">
    <svg class="fulfillment-notice__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M12 8.25v4.5M12 16.5h.007"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
    <p>Current fulfillment time for new orders is <strong>4&ndash;6 weeks</strong>.</p>
  </aside>

  <section class="hero">
    <div>
      <p class="eyebrow">The curler's stopwatch</p>
      <h1>Never miss another split</h1>
      <p class="hero-lede">
        Hog Splitter Pro is an interval timer designed around how curlers actually time rocks. Press one button as the
        stone crosses each line&mdash;it keeps every split organized for you.
      </p>
      <ul class="hero-points">
        <li><strong>Back-to-hog and hog-to-hog</strong> times, paired up shot by shot.</li>
        <li><strong>No resets, no modes, no alarms</strong> &mdash; just keep pressing split.</li>
        <li><strong>Glanceable history</strong> of recent shots. No scrolling or cycling.</li>
        <li><strong>Big e-paper display</strong>, crisp and readable from any angle.</li>
      </ul>
      <div class="hero-actions">
        <EtsySoon variant="button" />
        <a class="button-secondary" href="/guide/">Read the product guide</a>
      </div>
      <p class="order-availability">Available now &middot; $70 USD</p>
    </div>
    <div class="hero-screen-aside">
      <img
        class="hero-product-photo"
        src="/images/main.jpg"
        alt="Hand holding Hog Splitter Pro with split times on the e-paper display"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <hr class="hog-line" />

  <section class="testimonials" aria-label="Customer testimonials">
    <div
      class="testimonial-carousel"
      data-testimonial-carousel
      data-interval="20000"
    >
      <div class="testimonial-viewport">
        {
          testimonials.map((t, i) => (
            <figure
              class="testimonial-slide"
              data-testimonial-slide
              data-active={i === 0 ? "true" : "false"}
            >
              <blockquote class="testimonial-quote">{t.quote}</blockquote>
              <figcaption class="testimonial-author">&mdash; {t.author}</figcaption>
            </figure>
          ))
        }
      </div>
      <button
        type="button"
        class="testimonial-next"
        data-testimonial-next
        aria-label="Show next testimonial"
      >
        Next &rarr;
      </button>
    </div>
  </section>

  <section class="section" id="how" aria-labelledby="how-heading">
    <div class="section-heading">
      <p class="eyebrow">How it works</p>
      <h2 id="how-heading">One button. Every split organized.</h2>
    </div>
    <div class="how-grid">
      <div>
        <ol class="steps">
          <li>
            <strong>Press split at each line.</strong> The big readout shows the time between your last two presses.
          </li>
          <li>
            <strong>Times organize themselves.</strong> Short times (under 5.5 seconds) land in the left column as
            back-to-hog times; longer ones go right as hog-to-hog times.
          </li>
          <li>
            <strong>Each shot reads as one row.</strong> A short time followed by a long time pairs on the same line,
            so you can compare both splits for a shot at a glance.
          </li>
        </ol>
        <p class="how-footnote">
          There&apos;s no reset and nothing to clear between shots or ends&mdash;just keep splitting. Curious about the
          fine print, like long gaps, precision options, and idle behavior? It&apos;s all in the
          <a href="/guide/#timing">product guide</a>.
        </p>
      </div>
      <aside class="how-screen" aria-label="Simulated display example">
        <DeviceScreen variant="main" caption="Latest split up top; paired back-to-hog and hog-to-hog history below." />
      </aside>
    </div>
  </section>

  <section class="section" id="features" aria-labelledby="features-heading">
    <div class="section-heading">
      <p class="eyebrow">Features</p>
      <h2 id="features-heading">Small details, done right</h2>
    </div>
    <div class="feature-grid">
      <article class="feature-card">
        <h3>E-paper display</h3>
        <p>
          The same screen technology as an e-reader: high contrast, no glare, and easy to read in arena lighting from
          any angle.
        </p>
      </article>
      <article class="feature-card">
        <h3>Bonspiel-ready battery</h3>
        <p>
          USB-C rechargeable, with many hours of timing per charge. Charge before an event and you&apos;re set for the
          weekend.
        </p>
      </article>
      <article class="feature-card">
        <h3>Two split buttons</h3>
        <p>
          Both top buttons do the same thing&mdash;press whichever falls under your thumb. No modes to mix up
          mid-shot.
        </p>
      </article>
      <article class="feature-card">
        <h3>A beep you control</h3>
        <p>Tune the confirmation beep&apos;s volume, pitch, and duration&mdash;or turn it off entirely.</p>
      </article>
      <article class="feature-card">
        <h3>Your precision</h3>
        <p>
          Show tenths, hundredths, or thousandths of a second, and pick from three history font sizes to fit more (or
          bigger) times on screen.
        </p>
      </article>
      <article class="feature-card">
        <h3>Built by a curler</h3>
        <p>
          A programmable microcontroller in a custom 3D-printed ergonomic housing&mdash;designed, assembled, and tested
          in real curling matches.
        </p>
      </article>
    </div>
  </section>

  <section class="section" id="notes" aria-labelledby="notes-heading">
    <div class="section-heading">
      <p class="eyebrow">Practical notes</p>
      <h2 id="notes-heading">Good to know</h2>
      <p class="section-lede">
        Hog Splitter Pro is hand-built in small batches, so a few honest notes before you order:
      </p>
    </div>
    <div class="notes-grid">
      <article class="feature-card">
        <h3>Battery life</h3>
        <p>
          A charge lasts several hours&mdash;enough for a full event&mdash;but it does need periodic charging. For
          important games, start from a full charge shortly before you play.
        </p>
      </article>
      <article class="feature-card">
        <h3>Durability</h3>
        <p>
          Early users have run theirs for a full season without issues. Still, treat a hand-assembled device with some
          care, and keep it out of hot cars&mdash;e-paper is sensitive to high heat and UV light.
        </p>
      </article>
      <article class="feature-card">
        <h3>Display refresh</h3>
        <p>
          Like any e-paper screen, faint ghosting can linger between refreshes. Most curlers never notice it while
          timing.
        </p>
      </article>
    </div>
  </section>

  <section class="section" id="faq" aria-labelledby="faq-heading">
    <div class="section-heading">
      <p class="eyebrow">FAQ</p>
      <h2 id="faq-heading">Frequently asked questions</h2>
    </div>
    <div class="faq">
      <div class="faq-item">
        <h3>How do you reset it?</h3>
        <p>
          You don&apos;t&mdash;there&apos;s nothing to reset. Hog Splitter Pro is stateless: every press records a new
          split, and the history rolls forward on its own.
        </p>
      </div>
      <div class="faq-item">
        <h3>How long does it take to charge?</h3>
        <p>About 2&ndash;3 hours via USB-C.</p>
      </div>
      <div class="faq-item">
        <h3>How much does it cost?</h3>
        <p>
          $70.00 USD from the Hugs Curling Tech shop on <EtsySoon variant="inline" />. Customizations can be added for
          an additional fee.
        </p>
      </div>
      <div class="faq-item">
        <h3>When can I order one?</h3>
        <p>
          Order now on <EtsySoon variant="inline" />. Questions? <a href="#contact">Get in touch</a>.
        </p>
      </div>
      <div class="faq-item">
        <h3>Is this stopwatch legal to use in competitions?</h3>
        <p>
          The Rules of Curling state: &ldquo;With the exception of stopwatches that are limited to providing
          &lsquo;time&rsquo; data only, the use of electronic devices during the games, which provide information to
          players on the athletes&rsquo; field of play, are forbidden.&rdquo; This stopwatch only provides split times.
          Hog Splitter Pro has been used in multiple United States National Championships.
        </p>
      </div>
    </div>

    <div class="faq-subsection" aria-labelledby="policy-heading">
      <h3 id="policy-heading" class="faq-subsection__title">Return policy &amp; warranty</h3>
      <div class="faq">
        <div class="faq-item">
          <h3>Return policy</h3>
          <p>
            If you are not completely satisfied with Hog Splitter Pro, return the device within 90 days for a full
            refund, less any charges for customizations.
          </p>
        </div>
        <div class="faq-item">
          <h3>Warranty</h3>
          <p>
            One year limited warranty. If the device stops working under normal use within 12 months, we will repair or
            replace it free of charge.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="photos" aria-labelledby="photos-heading">
    <div class="section-heading">
      <p class="eyebrow">Product photos</p>
      <h2 id="photos-heading">Gallery</h2>
    </div>
    <div class="photo-grid">
      <img
        src="/images/marketing-1.jpg"
        alt="Hog Splitter Pro powered off, showing the wake screen"
        loading="lazy"
      />
      <img
        src="/images/marketing-2.jpg"
        alt="Blue Hog Splitter Pro displaying split times"
        loading="lazy"
      />
      <img
        src="/images/marketing-3.jpg"
        alt="Hog Splitter Pro with retractable belt clip attached"
        loading="lazy"
      />
      <img
        src="/images/marketing-4.jpg"
        alt="Hog Splitter Pro powered off with lanyard cord"
        loading="lazy"
      />
      <img
        class="photo-wide"
        src="/images/marketing-bottom.jpg"
        alt="Hog Splitter Pro in bronze, grey, and blue colorways"
        loading="lazy"
      />
    </div>
  </section>

  <section class="section" aria-labelledby="shop-heading">
    <div class="cta-band">
      <div>
        <p class="eyebrow">Hugs Curling Tech on Etsy</p>
        <h2 id="shop-heading">Dial in your draw weight</h2>
        <p>Hog Splitter Pro ships from the Hugs Curling Tech shop on Etsy. $70 USD, available now.</p>
      </div>
      <EtsySoon variant="button" />
    </div>
  </section>

  <section class="section" id="contact" aria-labelledby="contact-heading">
    <div class="contact-card">
      <div>
        <p class="eyebrow">Get in touch</p>
        <h2 id="contact-heading">Contact</h2>
        <p class="contact-card__lede">
          Have questions about Hog Splitter Pro, your order, or want to collaborate? Reach out.
        </p>
      </div>
      <a class="contact-email" href="mailto:hogsplitter@tgau.me">hogsplitter@tgau.me</a>
    </div>
    <p class="acknowledgements">
      Special thanks to Derek Corbett for 3D CAD design and playtesting, and to Drew Tingen for brainstorming and
      playtesting.
    </p>
  </section>
</SiteLayout>

<script>
  const carousel = document.querySelector<HTMLElement>("[data-testimonial-carousel]");

  if (carousel) {
    const slides = Array.from(
      carousel.querySelectorAll<HTMLElement>("[data-testimonial-slide]")
    );
    const nextBtn = carousel.querySelector<HTMLButtonElement>("[data-testimonial-next]");
    const intervalMs = Number(carousel.dataset.interval) || 10000;

    const viewport = carousel.querySelector<HTMLElement>(".testimonial-viewport");

    if (slides.length > 1 && viewport) {
      let current = 0;
      let timer: ReturnType<typeof setInterval> | undefined;

      // Reserve enough height for the tallest testimonial so swapping slides
      // never pushes the rest of the page up or down.
      const reserveHeight = () => {
        let tallest = 0;
        for (const slide of slides) {
          const wasActive = slide.dataset.active;
          slide.classList.add("is-measuring");
          slide.dataset.active = "true";
          tallest = Math.max(tallest, slide.getBoundingClientRect().height);
          slide.dataset.active = wasActive ?? "false";
          slide.classList.remove("is-measuring");
        }
        viewport.style.minHeight = `${Math.ceil(tallest)}px`;
      };

      reserveHeight();
      let resizeTimer: ReturnType<typeof setTimeout> | undefined;
      window.addEventListener("resize", () => {
        if (resizeTimer) clearTimeout(resizeTimer);
        resizeTimer = setTimeout(reserveHeight, 150);
      });

      const ANIM_MS = 500;

      const afterAnimation = (el: HTMLElement, className: string) => {
        let done = false;
        const finish = () => {
          if (done) return;
          done = true;
          el.classList.remove(className);
          el.removeEventListener("animationend", finish);
        };
        el.addEventListener("animationend", finish);
        // Fallback when animationend never fires (reduced motion, interrupted, etc.).
        window.setTimeout(finish, ANIM_MS + 50);
      };

      const show = (next: number) => {
        if (next === current) return;
        const outgoing = slides[current];
        const incoming = slides[next];

        // Drop stale animation state left by interrupted or skipped transitions.
        for (const slide of slides) {
          if (slide === outgoing || slide === incoming) continue;
          slide.classList.remove("is-leaving", "is-entering");
          slide.dataset.active = "false";
        }

        outgoing.classList.remove("is-entering");
        incoming.classList.remove("is-leaving");

        // Outgoing flies off to the left (kept visible via .is-leaving).
        outgoing.dataset.active = "false";
        outgoing.classList.add("is-leaving");
        afterAnimation(outgoing, "is-leaving");

        // Incoming slides in from the right.
        incoming.dataset.active = "true";
        incoming.classList.remove("is-entering");
        void incoming.offsetWidth;
        incoming.classList.add("is-entering");
        afterAnimation(incoming, "is-entering");

        current = next;
      };

      const advance = () => show((current + 1) % slides.length);

      const startTimer = () => {
        stopTimer();
        timer = setInterval(advance, intervalMs);
      };
      const stopTimer = () => {
        if (timer) clearInterval(timer);
        timer = undefined;
      };

      nextBtn?.addEventListener("click", () => {
        advance();
        // Reset the auto-cycle countdown after a manual advance.
        startTimer();
      });

      startTimer();
    }
  }
</script>

<style>
  .fulfillment-notice {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 0.9rem 1.15rem;
    border: 1px solid #e8c84a;
    border-left: 4px solid #c9a227;
    border-radius: var(--radius);
    background: #fff8dc;
    color: #5c4a12;
    font-size: 0.98rem;
    line-height: 1.45;
  }

  .fulfillment-notice__icon {
    flex-shrink: 0;
    width: 1.35rem;
    height: 1.35rem;
    margin-top: 0.1rem;
    color: #9a7b0a;
  }

  .fulfillment-notice p {
    margin: 0;
  }

  .fulfillment-notice strong {
    color: #3d3108;
  }

  .testimonials {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: clamp(1.75rem, 4vw, 2.75rem) 0 0;
  }

  .testimonial-carousel {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 3vw, 2rem);
    max-width: 52rem;
    margin: 0 auto;
    padding: 1.4rem 1.5rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    box-shadow: 0 10px 30px rgba(21, 38, 61, 0.05);
  }

  .testimonial-viewport {
    position: relative;
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .testimonial-slide {
    margin: 0;
    display: none;
  }

  .testimonial-slide[data-active="true"],
  .testimonial-slide.is-leaving {
    display: block;
  }

  .testimonial-slide.is-leaving {
    position: absolute;
    inset: 0;
    animation: testimonial-out 0.5s ease forwards;
  }

  /* Off-screen, non-animated state used only to measure slide heights. */
  .testimonial-slide.is-measuring {
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: auto;
    height: auto;
    visibility: hidden;
    animation: none;
  }

  .testimonial-slide.is-entering {
    animation: testimonial-in 0.5s ease forwards;
  }

  .testimonial-quote {
    margin: 0;
    color: #33455c;
    font-size: clamp(1rem, 1.6vw, 1.12rem);
    line-height: 1.55;
  }

  .testimonial-author {
    margin-top: 0.75rem;
    color: var(--navy);
    font-weight: 800;
  }

  .testimonial-next {
    flex-shrink: 0;
    align-self: center;
    min-height: 2.6rem;
    padding: 0.6rem 1.1rem;
    border: 1px solid rgba(21, 38, 61, 0.2);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.7);
    color: var(--navy);
    font-weight: 800;
    line-height: 1;
    cursor: pointer;
  }

  .testimonial-next:hover {
    border-color: rgba(21, 38, 61, 0.45);
    color: var(--brand);
  }

  @keyframes testimonial-in {
    from {
      opacity: 0;
      transform: translateX(100%);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes testimonial-out {
    from {
      opacity: 1;
      transform: translateX(0);
    }
    to {
      opacity: 0;
      transform: translateX(-100%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-slide.is-leaving,
    .testimonial-slide.is-entering {
      animation: none;
    }

    .testimonial-slide.is-leaving {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .testimonial-carousel {
      flex-direction: column;
      align-items: stretch;
    }

    .testimonial-next {
      align-self: flex-end;
    }
  }
</style>
